# FacilityOps — copy to .env and fill in values before running docker compose up

# Auth
SECRET_KEY=change-me-run-openssl-rand-hex-32
DEVICE_API_KEY=facilityops-dev-key

# Email alerts — leave blank to disable
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-alert-account@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=facilityops@yourcompany.com
ALERT_EMAIL_TO=ops-manager@yourcompany.com,shift-lead@yourcompany.com

# ServiceNow — leave blank to disable incident creation
SERVICENOW_INSTANCE=yourcompany.service-now.com
SERVICENOW_USERNAME=facilityops_api
SERVICENOW_PASSWORD=servicenow-password
SERVICENOW_ASSIGNMENT_GROUP=Facilities

# Mobile app — set in mobile/.env or Expo dashboard
# EXPO_PUBLIC_API_URL=http://192.168.1.x:8000
# EXPO_PUBLIC_API_KEY=facilityops-dev-key
